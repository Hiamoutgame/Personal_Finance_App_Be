// Render example:
//   dot -Tsvg docs/schema.dot -o docs/schema.from-dot.svg

digraph schema_overview {
  graph [
    rankdir=LR,
    splines=ortho,
    pad="0.25",
    nodesep="0.55",
    ranksep="0.85",
    newrank=true,
    compound=true,
    bgcolor="#f7f8fc",
    fontname="Segoe UI"
  ];

  node [
    shape=plain,
    fontname="Segoe UI",
    margin=0
  ];

  edge [
    color="#4b5563",
    penwidth=1.5,
    arrowsize=0.7,
    fontname="Segoe UI",
    fontsize=10
  ];

  subgraph cluster_identity {
    label="Identity / Onboarding / Admin";
    labelloc="t";
    fontsize=18;
    fontname="Segoe UI Bold";
    color="#d7dce8";
    style="rounded,filled";
    fillcolor="#ffffff";

    roles [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>roles</b></td></tr>
        <tr><td align="left">PK id smallint<br align="left"/>code<br align="left"/>name</td></tr>
      </table>
    >];

    accounts [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>accounts</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK role_id<br align="left"/>username<br align="left"/>password_hash</td></tr>
      </table>
    >];

    onboarding_profiles [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>onboarding_profiles</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK user_id<br align="left"/>recommended_method</td></tr>
      </table>
    >];

    ai_settings [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>ai_settings</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK updated_by_admin_id<br align="left"/>model_name</td></tr>
      </table>
    >];

    audit_logs [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>audit_logs</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK actor_account_id<br align="left"/>metadata_json</td></tr>
      </table>
    >];

    roles -> accounts [label="1..N"];
    accounts -> onboarding_profiles [label="1..1"];
    accounts -> ai_settings [label="0..N admin updates"];
    accounts -> audit_logs [label="0..N acts"];
  }

  subgraph cluster_money {
    label="Money Sources / Categories / Jars";
    labelloc="t";
    fontsize=18;
    fontname="Segoe UI Bold";
    color="#d7dce8";
    style="rounded,filled";
    fillcolor="#ffffff";

    financial_accounts [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>financial_accounts</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK user_id<br align="left"/>account_type<br align="left"/>current_balance</td></tr>
      </table>
    >];

    categories [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>categories</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK owner_user_id<br align="left"/>is_default</td></tr>
      </table>
    >];

    jar_setups [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>jar_setups</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK user_id<br align="left"/>method_type</td></tr>
      </table>
    >];

    jars [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>jars</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK user_id<br align="left"/>FK jar_setup_id<br align="left"/>balance</td></tr>
      </table>
    >];

    accounts -> financial_accounts [label="1..N owns"];
    accounts -> categories [label="0..N custom"];
    accounts -> jar_setups [label="1..1 configures"];
    accounts -> jars [label="1..N owns"];
    jar_setups -> jars [label="0..N defines"];
  }

  subgraph cluster_transactions {
    label="Transactions / Imports";
    labelloc="t";
    fontsize=18;
    fontname="Segoe UI Bold";
    color="#d7dce8";
    style="rounded,filled";
    fillcolor="#ffffff";

    import_jobs [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>import_jobs</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK user_id<br align="left"/>FK financial_account_id</td></tr>
      </table>
    >];

    transactions [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>transactions</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK user_id / financial_account_id<br align="left"/>transactions_amount<br align="left"/>FK from_jar_id / to_jar_id</td></tr>
      </table>
    >];

    import_transaction_drafts [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>import_transaction_drafts</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK import_job_id<br align="left"/>FK edited_category_id<br align="left"/>FK edited_jar_id</td></tr>
      </table>
    >];

    accounts -> import_jobs [label="1..N uploads"];
    financial_accounts -> import_jobs [label="1..N belongs_to"];
    import_jobs -> import_transaction_drafts [label="1..N parses"];
    import_jobs -> transactions [label="0..N confirms"];
    accounts -> transactions [label="1..N records"];
    financial_accounts -> transactions [label="1..N source"];
    categories -> transactions [label="0..N classifies"];
    jars -> transactions [label="0..N from/to jar"];
    categories -> import_transaction_drafts [label="0..N edited cat"];
    jars -> import_transaction_drafts [label="0..N edited jar"];
  }

  subgraph cluster_planning {
    label="Limits / Goals / Reminders / Notifications";
    labelloc="t";
    fontsize=18;
    fontname="Segoe UI Bold";
    color="#d7dce8";
    style="rounded,filled";
    fillcolor="#ffffff";

    spending_limits [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>spending_limits</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK user_id / jar_id / category_id<br align="left"/>limit_amount</td></tr>
      </table>
    >];

    goals [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>goals</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK user_id / linked_jar_id<br align="left"/>target_amount</td></tr>
      </table>
    >];

    goal_contributions [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>goal_contributions</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK goal_id / user_id<br align="left"/>FK source_jar_id<br align="left"/>amount</td></tr>
      </table>
    >];

    reminders [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>reminders</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK user_id / category_id<br align="left"/>start_date<br align="left"/>day_of_month</td></tr>
      </table>
    >];

    broadcasts [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>broadcasts</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK created_by_admin_id<br align="left"/>status</td></tr>
      </table>
    >];

    notifications [label=<
      <table border="1" cellborder="0" cellspacing="0" cellpadding="6" color="#243041">
        <tr><td bgcolor="#edf3ff" align="left"><b>notifications</b></td></tr>
        <tr><td align="left">PK id<br align="left"/>FK user_id / broadcast_id<br align="left"/>metadata_json</td></tr>
      </table>
    >];

    accounts -> spending_limits [label="1..N sets"];
    jars -> spending_limits [label="0..N target"];
    categories -> spending_limits [label="0..N target"];
    accounts -> goals [label="1..N owns"];
    jars -> goals [label="0..N linked"];
    goals -> goal_contributions [label="1..N receives"];
    accounts -> goal_contributions [label="1..N makes"];
    jars -> goal_contributions [label="0..N source"];
    accounts -> reminders [label="1..N creates"];
    categories -> reminders [label="0..N tags"];
    accounts -> broadcasts [label="0..N admin creates"];
    broadcasts -> notifications [label="0..N fans_out"];
    accounts -> notifications [label="1..N receives"];
  }
}
