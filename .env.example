API_PORT=8080
API_CONTAINER_PORT=8080
ASPNETCORE_ENVIRONMENT=Development
APPLY_MIGRATIONS=false

# Backend-only deploy can boot without a live database as long as migrations are off.
# Endpoints that read/write data still need a real database later.
CONNECTION_STRING=Host=localhost;Port=5432;Database=PersonalFinanceManagementDb;Username=postgres;Password=postgres123

JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
JWT_ISSUER=PersonalFinanceManagement
JWT_AUDIENCE=PersonalFinanceManagement
JWT_EXPIRE_MINUTES=120

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

MAIL_ADDRESS=
MAIL_DISPLAY_NAME=Personal Finance
MAIL_PASSWORD=
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
